<Window x:Class="AhuErp.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AhuErp.UI.ViewModels"
        xmlns:views="clr-namespace:AhuErp.UI.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="МКУ «АХУ» БМР — документооборот и управленческий учет"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OfficeViewModel}">
            <views:OfficeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArchiveViewModel}">
            <views:ArchiveView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItServiceViewModel}">
            <views:ItServiceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WarehouseViewModel}">
            <views:WarehouseView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FleetViewModel}">
            <views:FleetView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RkkViewModel}">
            <views:RkkView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MyTasksViewModel}">
            <views:MyTasksView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NomenclatureViewModel}">
            <views:NomenclatureView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditJournalViewModel}">
            <views:AuditJournalView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:JournalViewModel}">
            <views:JournalView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <views:SearchView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Brush.Sidebar.Background}">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" Margin="20,24,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="/AhuErp.UI;component/Assets/balashov-coa.png"
                           Width="44" Height="56"
                           Stretch="Uniform"
                           VerticalAlignment="Top"
                           Margin="0,0,12,0"
                           ToolTip="Герб города Балашов" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="МКУ «АХУ» БМР"
                                   Foreground="{StaticResource Brush.Sidebar.Foreground}"
                                   FontSize="18" FontWeight="Bold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Документооборот и учет"
                                   Foreground="{StaticResource Brush.Sidebar.Accent}"
                                   FontSize="12" Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Border DockPanel.Dock="Top"
                        Background="#16202F"
                        Margin="12,0,12,12"
                        Padding="12,8"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUserDisplayName}"
                                   Foreground="{StaticResource Brush.Sidebar.Foreground}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CurrentUserRoleDisplayName}"
                                   Foreground="{StaticResource Brush.Sidebar.Accent}"
                                   FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource NavButton}"
                        Content="Выйти"
                        Margin="0,8,0,8"
                        Command="{Binding LogoutCommand}" />

                <ItemsControl ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource NavButton}"
                                    Content="{Binding Title}"
                                    Visibility="{Binding IsAllowed, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource Brush.Content.Background}">
            <DockPanel LastChildFill="True">
                <!-- Верхняя панель: «колокольчик» уведомлений + popover. -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource Brush.Sidebar.Background}"
                        Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SelectedNavigationItem.Title}"
                                   Foreground="{StaticResource Brush.Sidebar.Foreground}"
                                   FontSize="14" VerticalAlignment="Center" />
                        <Grid Grid.Column="1">
                            <ToggleButton x:Name="BellButton"
                                          IsChecked="{Binding IsNotificationsOpen, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Foreground="{StaticResource Brush.Sidebar.Foreground}"
                                          Padding="8,4"
                                          Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔔" FontSize="16" />
                                    <Border Background="#E74C3C"
                                            CornerRadius="8"
                                            Padding="6,1"
                                            Margin="6,0,0,0"
                                            Visibility="{Binding UnreadNotificationCount, Converter={StaticResource IntToVisibilityConverter}}">
                                        <TextBlock Text="{Binding UnreadNotificationCount}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=BellButton}"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=BellButton}"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"
                                        Padding="12"
                                        Width="380"
                                        MaxHeight="420">
                                    <DockPanel LastChildFill="True">
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Уведомления"
                                                       FontWeight="Bold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Content="Прочитано"
                                                    Padding="8,2"
                                                    Command="{Binding MarkAllNotificationsReadCommand}" />
                                        </Grid>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Notifications}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#EEEEEE"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="0,6">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Body}"
                                                                           TextWrapping="Wrap"
                                                                           Foreground="#444"
                                                                           FontSize="11" />
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat=g}"
                                                                           Foreground="#888"
                                                                           FontSize="10"
                                                                           Margin="0,2,0,0" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Grid>
                </Border>
                <ContentControl Content="{Binding CurrentViewModel}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
